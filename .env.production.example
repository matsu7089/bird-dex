# DB (docker-compose.prod.yml 用)
POSTGRES_USER=birdlog
POSTGRES_PASSWORD=changeme
POSTGRES_DB=birdlog
DATABASE_URL=postgres://birdlog:changeme@db:5432/birdlog

# Blob (Azure 本番)
BLOB_ENDPOINT=https://<account>.blob.core.windows.net
BLOB_ACCESS_KEY=<storage-account-name>
BLOB_SECRET_KEY=<storage-account-key>
BLOB_BUCKET=birdlog-photos

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=https://<api-fqdn>/auth/github/callback

# Session
SESSION_SECRET=<32文字以上のランダム文字列>

# App
NODE_ENV=production
PORT=3000
CORS_ORIGIN=https://<web-fqdn>

# Frontend build-time
VITE_API_URL=https://<api-fqdn>
