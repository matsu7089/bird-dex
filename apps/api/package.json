{
  "name": "@bird-dex/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push --force",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.27.0",
    "@bird-dex/shared": "workspace:*",
    "@hono/node-server": "^1.14.1",
    "arctic": "^3.7.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.43.1",
    "exifr": "^7.1.3",
    "hono": "^4.7.7",
    "pg": "^8.14.1",
    "sharp": "^0.34.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/pg": "^8.11.11",
    "@types/sharp": "^0.32.0",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
