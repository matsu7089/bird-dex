{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@bird-dex/shared": ["../../packages/shared/src/types.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
