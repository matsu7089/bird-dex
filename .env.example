# Database
DATABASE_URL=postgres://birdlog:birdlog@localhost:5432/birdlog

# Blob Storage (RustFS locally, Azure Blob in production)
BLOB_ENDPOINT=http://localhost:9000
BLOB_ACCESS_KEY=rustfsadmin
BLOB_SECRET_KEY=rustfsadmin
BLOB_BUCKET=birdlog-photos

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:3000/auth/github/callback

# Session
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# App
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Frontend (Vite exposes VITE_* vars to browser)
VITE_API_URL=http://localhost:3000
